# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SERENITÀ — Variabili d'Ambiente
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copia questo file in .env e compila i valori

# ── Database (Supabase) ────────────────────────────────────────
# Vai su https://supabase.com → New Project → Settings → Database
# Copia "Connection string" (URI) e metti qui
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ── Autenticazione ─────────────────────────────────────────────
# Genera una stringa random: openssl rand -base64 32
NEXTAUTH_SECRET="genera-una-stringa-random-qui"
NEXTAUTH_URL="http://localhost:3000"

# ── Provider API Keys (fase successiva, non servono subito) ────
# TINK_CLIENT_ID=""
# TINK_CLIENT_SECRET=""
# SALTEDGE_APP_ID=""
# SALTEDGE_SECRET=""
# PAYPAL_CLIENT_ID=""
# PAYPAL_SECRET=""
# SATISPAY_KEY_ID=""
# SATISPAY_PRIVATE_KEY=""
